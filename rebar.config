%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_vector

{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, []}.

%% NOTE: rustler / rebar3_cargo intentionally NOT declared as deps.
%%
%% Rustler 0.34 pulls in Elixir-side hex transitives (nimble_csv,
%% jason) that rebar3 can't compile without a mix builder. The NIF
%% Erlang side compiles fine without rustler being on the BEAM
%% code path — `hecate_vector_nif.erl` only needs `on_load` +
%% `erlang:nif_error/1` stubs.
%%
%% To actually BUILD the NIF .so, run scripts/build-nif.sh
%% (invokes cargo directly). The Rust crate uses `rustler` from
%% crates.io; that's a Rust dep, not a hex dep — no rebar3
%% involvement.
%%
%% When the rustler-hex compatibility story improves (or we vendor
%% the parts we need), re-add `{deps, [{rustler, "..."}]}` and the
%% cargo provider_hook here.
{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

{shell, [
    {apps, [hecate_vector]}
]}.

{hex, [
    {name, hecate_vector},
    {doc, #{provider => ex_doc}},
    {licenses, ["Apache-2.0"]},
    {links, #{
        <<"Codeberg">> => <<"https://codeberg.org/hecate-social/hecate-vector">>
    }},
    {description, "In-BEAM HNSW vector index for Hecate (Rustler NIF over USearch)"}
]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-social/hecate-vector">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE", "guides/getting_started.md"]},
    {main, "README.md"}
]}.
